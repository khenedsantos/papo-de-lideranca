generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}

enum ReadingProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum BookLevel {
  ESSENTIAL
  DEEPENING
  PROVOCATION
}

enum BookNoteStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                    String            @id @default(cuid())
  name                  String
  email                 String            @unique
  avatarUrl             String?
  passwordHash          String
  role                  UserRole          @default(MEMBER)
  isActive              Boolean           @default(true)
  hasCompletedAccess    Boolean           @default(false)
  resetPasswordToken    String?
  resetPasswordExpiresAt DateTime?
  lastLoginAt           DateTime?
  weeklyReadingTarget   Int               @default(5)
  subscriptions         Subscription[]
  readingProgress       ReadingProgress[]
  dailyReadingActivities DailyReadingActivity[]
  bookNotes             BookNote[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  status    SubscriptionStatus @default(ACTIVE)
  plan      SubscriptionPlan   @default(FREE)
  startedAt DateTime
  endsAt    DateTime?
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId])
}

model Category {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String
  articles      Article[]
  shortEditions ShortEdition[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Article {
  id              String            @id @default(cuid())
  title           String
  slug            String            @unique
  excerpt         String
  content         String
  readTimeMinutes Int
  isPublished     Boolean           @default(false)
  publishedAt     DateTime?
  categoryId      String
  category        Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  readingProgress ReadingProgress[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([categoryId])
}

model ShortEdition {
  id              String            @id @default(cuid())
  title           String
  slug            String            @unique
  excerpt         String
  ideaCentral     String
  whatMatters     Json
  applyToday      Json
  quoteOfWeek     String
  readTimeMinutes Int
  isPublished     Boolean           @default(false)
  publishedAt     DateTime?
  categoryId      String
  category        Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  readingProgress ReadingProgress[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([categoryId])
}

model ReadingProgress {
  id              String                @id @default(cuid())
  userId          String
  articleId       String?
  shortEditionId  String?
  progressPercent Int                   @default(0)
  status          ReadingProgressStatus @default(NOT_STARTED)
  lastReadAt      DateTime              @default(now())
  completedAt     DateTime?
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  article         Article?              @relation(fields: [articleId], references: [id], onDelete: Cascade)
  shortEdition    ShortEdition?         @relation(fields: [shortEditionId], references: [id], onDelete: Cascade)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([articleId])
  @@index([shortEditionId])
  @@index([userId, lastReadAt])
  @@unique([userId, articleId])
  @@unique([userId, shortEditionId])
}

model DailyReadingActivity {
  id             String   @id @default(cuid())
  userId         String
  activityDate   DateTime @db.Date
  minutesRead    Int      @default(0)
  completedCount Int      @default(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, activityDate])
  @@unique([userId, activityDate])
}

model Book {
  id                       String     @id @default(cuid())
  slug                     String     @unique
  title                    String
  subtitle                 String?
  author                   String
  description              String
  coverUrl                 String?
  coverAlt                 String?
  category                 String
  level                    BookLevel
  readTime                 String?
  whyRead                  String
  whatYouWillLearn         Json?
  keyIdeas                 Json?
  guidedQuestions          Json?
  practicalUse             String?
  relatedArticleSlugs      Json?
  relatedShortEditionSlugs Json?
  purchaseUrl              String?
  purchaseLabel            String?
  purchaseProvider         String?
  isFeatured               Boolean    @default(false)
  isActive                 Boolean    @default(true)
  displayOrder             Int        @default(0)
  notes                    BookNote[]
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@index([category])
  @@index([level])
  @@index([isActive, displayOrder])
}

model BookNote {
  id            String         @id @default(cuid())
  userId        String
  bookId        String
  promptKey     String
  content       String
  status        BookNoteStatus @default(PENDING)
  isHighlighted Boolean        @default(false)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  book          Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([bookId, status, isHighlighted])
  @@index([userId])
  @@unique([userId, bookId, promptKey])
}
